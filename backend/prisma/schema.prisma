// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReadingStatus {
  NOT_STARTED
  READING
  FINISHED
  DROPPED
}

model User {
  id            String            @id @default(uuid())
  name          String
  email         String            @unique
  avatarUrl     String?
  bio           String?
  library       LibraryItem[]
  collections   Collection[]
  reviews       Review[]
  memberships   GroupMember[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Book {
  id            String            @id @default(uuid())
  title         String            
  author        String
  coverUrl      String?
  description   String?
  pageCount     Int?
  publishedYear Int?
  libraryItems  LibraryItem[]
  reviews       Review[]
  groups        Group[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model LibraryItem {
  id                  String            @id @default(uuid())
  userId              String
  bookId              String
  ReadingStatus       ReadingStatus     @default(NOT_STARTED)
  progressPercent     Int               @default(0)
  rating              Int?
  notes               String?
  startedAt           DateTime?
  finishedAt          DateTime?
  dateAdded           DateTime?         @default(now())
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  collectionBooks     CollectionBook[]

  @@unique([userId, bookId])
}

model Collection {
  id                  String            @id @default(uuid())
  userId              String
  name                String
  description         String?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  books               CollectionBook[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}


model CollectionBook {
  id                  String            @id @default(uuid())
  collectionId        String
  libraryItemId       String
  collection          Collection        @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  libraryItem         LibraryItem       @relation(fields: [libraryItemId], references:  [id], onDelete: Cascade)

  @@unique([collectionId, libraryItemId])
}

model Review {
  id                String            @id @default(uuid())
  userId            String
  bookId            String
  rating            Int
  title             String?
  body              String
  notes             String?
  difficulty        Int?
  recommended       Boolean?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  book              Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Group {
  id                  String            @id @default(uuid())
  name                String
  description         String?
  currentBookId       String?
  startDate           DateTime?
  endDate             DateTime?
  currentBook         Book?            @relation(fields: [currentBookId], references: [id])
  members             GroupMember[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}



model GroupMember {
  id                  String            @id @default(uuid())
  groupId             String
  userId              String
  group               Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}